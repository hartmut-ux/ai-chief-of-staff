# Chief of Staff environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# LLM provider keys (use the one your Kimi setup routes through)
OPENAI_API_KEY=sk-...
KIMI_API_KEY=...

# MCP server names as registered in Kimi Code CLI
GMAIL_MCP_NAME=gmail
CALENDAR_MCP_NAME=calendar
NOTION_MCP_NAME=notion
SLACK_MCP_NAME=slack

# Gmail OAuth2 credentials
# Download credentials.json from Google Cloud Console > APIs & Services > Credentials.
# GMAIL_CREDENTIALS=/path/to/gmail-credentials.json
# GMAIL_TOKEN=/path/to/gmail-token.json

# Google Calendar OAuth2 credentials
# Can reuse the same OAuth client if both Gmail and Calendar APIs are enabled.
# CALENDAR_CREDENTIALS=/path/to/calendar-credentials.json
# CALENDAR_TOKEN=/path/to/calendar-token.json

# Notion integration
# NOTION_TOKEN=secret_...
# NOTION_DATABASE_ID=...
# NOTION_BRIEFING_PAGE_ID=...

# Slack channel webhook for delivery
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Telegram delivery
# TELEGRAM_BOT_TOKEN=...
# TELEGRAM_CHAT_ID=...

# Email delivery settings (for sending briefings)
# SMTP_HOST=smtp.example.com
# SMTP_USER=you@example.com
# SMTP_PASS=...
# EMAIL_TO=you@example.com

# Custom source integration
# CUSTOM_API_URL=https://api.example.com/v1
# CUSTOM_API_KEY=
