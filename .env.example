# Chief of Staff environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# LLM provider keys (use the one your Kimi setup routes through)
OPENAI_API_KEY=sk-...
KIMI_API_KEY=...

# MCP server names as registered in Kimi Code CLI
GMAIL_MCP_NAME=gmail
CALENDAR_MCP_NAME=calendar
NOTION_MCP_NAME=notion
SLACK_MCP_NAME=slack

# Notion target database for task/briefing writes
NOTION_DATABASE_ID=

# Slack channel webhook for delivery
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Email delivery settings (for sending briefings)
SMTP_HOST=smtp.example.com
SMTP_USER=you@example.com
SMTP_PASS=...
EMAIL_TO=you@example.com

# Custom source integration
CUSTOM_API_URL=https://api.example.com/v1
CUSTOM_API_KEY=
